{
  "schemaVersion": 1,
  "autoMigrate": true,
  "tokenizer": "cl100k_base",
  "providers": [],
  "roots": [],
  "ignore": [],
  "scan": {
    "tokenize": true,
    "strict": false,
    "followSymlinks": false,
    "maxFileSizeBytes": 1048576,
    "watch": {
      "debounceMs": 300
    }
  },
  "plugins": {},
  "history": {
    "share": false
  },
  "jobs": {
    "ttlSeconds": 3600,
    "graceMultiplier": 3,
    "minimumTtlSeconds": 60,
    "perActionTtl": {},
    "perActionPriority": {},
    "retention": {
      "completed": 2592000,
      "failed": null
    }
  },
  "i18n": {
    "locale": "en"
  }
}
