{
  "name": "skill-map-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "skill-map monorepo — houses the public spec and the reference implementation.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crystian/skill-map.git"
  },
  "workspaces": [
    "spec",
    "src",
    "testkit",
    "ui"
  ],
  "scripts": {
    "start": "npm start --workspace=ui",
    "spec:index": "node scripts/build-spec-index.mjs",
    "spec:check": "node scripts/build-spec-index.mjs --check && node scripts/check-coverage.mjs",
    "spec:coverage": "node scripts/check-coverage.mjs",
    "cli:reference": "node scripts/build-cli-reference.mjs",
    "cli:check": "node scripts/build-cli-reference.mjs --check",
    "site:build": "node scripts/build-site.mjs",
    "web": "node scripts/dev-server.mjs",
    "web:docker:build": "docker build -t skill-map-test .",
    "web:docker:run": "docker run --rm -p 8080:8080 skill-map-test",
    "web:docker": "npm run web:docker:build && npm run web:docker:run",
    "sqlite": "node scripts/open-sqlite-browser.mjs",
    "build": "npm run build --workspace=@skill-map/cli",
    "typecheck": "npm run typecheck --workspace=@skill-map/cli",
    "test": "npm run test --workspace=@skill-map/cli",
    "changeset": "changeset",
    "changeset:version": "changeset version && npm run spec:index",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0"
  },
  "engines": {
    "node": ">=24.0"
  }
}
